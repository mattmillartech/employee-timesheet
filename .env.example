# --- Frontend (baked into the Vite bundle at BUILD time) ---

# Google OAuth 2.0 Web Client ID (from GCP Console → APIs & Services → Credentials).
# This IS tied to a specific GCP project (forkers provide their own). The
# Client ID is public-by-design — it ships in the JS bundle anyway, so having
# it in the build env is not a secret leak.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Optional — comma-separated allowlist of Google account emails permitted to
# sign in. Leave empty to allow any Google account that passes your GCP
# OAuth consent screen (which, while the app is in "Testing" mode, is gated
# by the consent screen's test-user list).
VITE_ALLOWED_GOOGLE_EMAIL=

# Optional — default sheet ID baked into the bundle. On first sign-in, each
# user either (a) has a prior sheet ID in localStorage, (b) falls back to
# this env var, or (c) gets a fresh sheet auto-created in their Drive.
# Leave empty for multi-user deployments where each user should get their own.
VITE_SHEET_ID=

# --- Sidecar ---
# The sidecar no longer needs any runtime secrets. /api/* requests carry
# their own `Authorization: Bearer <oauth-access-token>` header and
# `?sheetId=<sheet-id>` query param, so the container has no account-specific
# state and is safe to share publicly.
