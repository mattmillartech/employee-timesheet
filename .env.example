# --- Frontend (baked into the Vite bundle at BUILD time — not runtime) ---
# Google OAuth 2.0 Web Client ID (from GCP Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Email allowlist — only this Google account can sign in and use the app.
VITE_ALLOWED_GOOGLE_EMAIL=you@example.com

# Google Sheet ID (the long opaque part of the sheet URL between /d/ and /edit).
VITE_SHEET_ID=your-google-sheet-id-here

# --- Sidecar (runtime-only; never exposed to the browser bundle) ---
# Paste the ENTIRE service account JSON here as a single line, single-quoted.
# Quote preserves the \n sequences inside private_key; docker-compose parses it
# correctly as long as the value is wrapped in single quotes.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# Random 48+ character secret for the /api/* bearer header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_API_KEY=generate-a-long-random-secret-string-here
